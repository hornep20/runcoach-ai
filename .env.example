# PostgreSQL (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/runcoach?schema=public"

# Intervals.icu — Developer Settings → API key (Basic auth user is always API_KEY)
INTERVALS_ICU_API_KEY=""
# Optional: numeric athlete id from Intervals; use "0" for the account tied to the API key
INTERVALS_ICU_ATHLETE_ID="0"
# Optional override (default https://intervals.icu)
# INTERVALS_ICU_BASE_URL="https://intervals.icu"

# POST /api/sync/intervals — send header X-Sync-Secret with this value (use a long random string)
SYNC_SECRET_TOKEN=""

# OpenAI — AI coach (chat + embeddings). Create a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=""
# Optional chat model (default gpt-4o-mini)
# OPENAI_CHAT_MODEL="gpt-4o-mini"

# Prisma Athlete.id to attach imported activities (or omit to use first athlete in DB)
# RUNCOACH_DEFAULT_ATHLETE_ID=""
